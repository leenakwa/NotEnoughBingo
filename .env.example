# Copy this file to .env for local development. Values in this file are
# deliberately non-production credentials. Never reuse them outside local dev.

# Project
COMPOSE_PROJECT_NAME=not-enough-bingo
APP_PORT=8080
BIND_ADDRESS=127.0.0.1
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.05

# Frontend
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_APP_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_CSRF_COOKIE_NAME=neb_csrf
API_BASE_URL=http://backend:8000/api/v1

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=true
DJANGO_SECRET_KEY=insecure-local-only-change-before-any-shared-environment
ALLOWED_HOSTS=localhost,127.0.0.1,backend,proxy
CSRF_TRUSTED_ORIGINS=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SESSION_COOKIE_AGE=1209600
SECURE_HSTS_SECONDS=0
# One trusted reverse proxy (the local Nginx service) appends X-Forwarded-For.
# Production must set the exact number of trusted ingress hops.
TRUSTED_PROXY_HOPS=1
FRONTEND_URL=http://localhost:8080

# PostgreSQL
POSTGRES_IMAGE_TAG=16-alpine
POSTGRES_DB=not_enough_bingo
POSTGRES_USER=not_enough_bingo
POSTGRES_PASSWORD=local-postgres-change-me
POSTGRES_PORT=5432
DATABASE_URL=postgresql://not_enough_bingo:local-postgres-change-me@postgres:5432/not_enough_bingo
DB_CONN_MAX_AGE=60

# Redis and Celery
REDIS_IMAGE_TAG=7-alpine
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_TIME_LIMIT_SECONDS=900
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=840

# Object storage. Local development uses MinIO.
MINIO_IMAGE_TAG=RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE_TAG=RELEASE.2025-08-13T08-35-41Z
MINIO_ROOT_USER=minio-local
MINIO_ROOT_PASSWORD=minio-local-change-me
MINIO_API_CORS_ALLOW_ORIGIN=http://localhost:8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
USE_S3=true
S3_ACCESS_KEY=neb-service
S3_SECRET_KEY=neb-service-local-change-me
S3_BUCKET=not-enough-bingo-local
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
MEDIA_UPLOAD_URL_TTL_SECONDS=900
MEDIA_ORPHAN_RETENTION_HOURS=24
MEDIA_AVATAR_MAX_BYTES=5242880
MEDIA_COVER_MAX_BYTES=8388608
MEDIA_BACKGROUND_MAX_BYTES=12582912
MEDIA_CELL_IMAGE_MAX_BYTES=5242880
MEDIA_MAX_ACTIVE_UPLOAD_INTENTS=100
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/avif
MAX_UPLOAD_BYTES=15728640
MAX_CELL_IMAGES_PER_BINGO=100

# Email. Local development uses Mailpit.
MAILPIT_IMAGE_TAG=v1.30.4
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=Not Enough Bingo <no-reply@localhost>
EMAIL_VERIFICATION_TTL_SECONDS=86400
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_PER_DAY=10
PASSWORD_RESET_TTL_SECONDS=3600

# Authentication and abuse controls
AUTH_LOGIN_RATE_LIMIT=5/m
AUTH_REGISTER_RATE_LIMIT=5/h
AUTH_PASSWORD_RESET_RATE_LIMIT=3/h
AUTH_EMAIL_VERIFICATION_RATE_LIMIT=5/h
COMMENT_RATE_LIMIT=10/m
REPORT_RATE_LIMIT=5/h
UPLOAD_RATE_LIMIT=30/h
ACCOUNT_DELETION_GRACE_DAYS=14
ACCOUNT_EXPORT_RETENTION_HOURS=24
# Local seed command only; never configure or run seed_dev in production.
DEV_SEED_PASSWORD=LocalDevPassword!123

# Reverse proxy
NGINX_IMAGE_TAG=1.30.3-alpine
NGINX_CLIENT_MAX_BODY_SIZE=16m

# Local backup scripts
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
