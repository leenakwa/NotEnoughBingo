# Browser requests use the same-origin Next.js rewrite by default.
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Public origin used for absolute metadata URLs.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Used only by the Next.js server/rewrite. In Docker this is normally backend:8000.
API_BASE_URL=http://127.0.0.1:8000/api/v1

# Django's CSRF cookie name.
NEXT_PUBLIC_CSRF_COOKIE_NAME=neb_csrf

# Used by Playwright.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
