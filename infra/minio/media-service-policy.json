{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BucketMetadata",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucketMultipartUploads"
      ],
      "Resource": [
        "arn:aws:s3:::__S3_BUCKET__"
      ]
    },
    {
      "Sid": "ListApplicationPrefixes",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::__S3_BUCKET__"
      ],
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "staging/uploads/*",
            "media/*",
            "exports/*"
          ]
        }
      }
    },
    {
      "Sid": "ApplicationObjects",
      "Effect": "Allow",
      "Action": [
        "s3:AbortMultipartUpload",
        "s3:DeleteObject",
        "s3:GetObject",
        "s3:ListMultipartUploadParts",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::__S3_BUCKET__/staging/uploads/*",
        "arn:aws:s3:::__S3_BUCKET__/media/*",
        "arn:aws:s3:::__S3_BUCKET__/exports/*"
      ]
    }
  ]
}
